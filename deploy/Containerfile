# Stage 1: Build React frontend
FROM node:22-slim AS frontend-build
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app
COPY frontend/package.json frontend/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY frontend/ ./
RUN pnpm run build

# Stage 2: Production image
FROM python:3.12-slim

LABEL org.opencontainers.image.title="Industrial Datagen"
LABEL org.opencontainers.image.description="Industrial process simulation platform for AI/ML dataset generation"
LABEL org.opencontainers.image.version="0.1.0"
LABEL org.opencontainers.image.vendor="Red Hat Demo"

RUN apt-get update && apt-get install -y --no-install-recommends gcc libc6-dev && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

WORKDIR /app

COPY backend/pyproject.toml ./
RUN uv pip install --system --no-cache .

COPY backend/app/ ./app/

COPY --from=frontend-build /app/dist ./static/

ENV INDGEN_CORS_ORIGINS='["*"]'
ENV INDGEN_STATIC_DIR=/app/static

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
